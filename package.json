{
  "name": "@basilafro/fluid-clamp",
  "version": "2.0.0",
  "description": "Tailwind CSS plugin for fluid clamp utilities using cqw, cqh, and vw",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BasilAfro/fluid-clamp.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.0.0"
  },
  "devDependencies": {
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "tailwindcss",
    "tailwind-plugin",
    "fluid",
    "clamp",
    "container-queries",
    "cqw",
    "responsive"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
